<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>VGC College</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">VGC College</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <!-- 🔥 MENU PRINCIPAL -->
                <ul class="navbar-nav">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <!-- ADMIN + FACULTY -->
                        @if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Courses" asp-action="Index">Courses</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Students" asp-action="Index">Students</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Enrollments" asp-action="Index">Enrollments</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Assignments" asp-action="Index">Assignments</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Exams" asp-action="Index">Exams</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AssignmentResults" asp-action="Index">Assignment Results</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ExamResults" asp-action="Index">Exam Results</a>
                            </li>
                        }

                        <!-- 👨‍🎓 STUDENT -->
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Assignments" asp-action="MyAssignments">
                                    My Assignments
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Exams" asp-action="MyExams">
                                    My Exams
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Gradebook" asp-action="MyGrades">
                                    My Grades
                                </a>
                            </li>
                        }
                    }

                </ul>

                <!-- 🔐 LOGIN / LOGOUT -->
                <ul class="navbar-nav ms-auto">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-white">
                                👋 Hello @User.Identity.Name
                            </span>
                        </li>

                        <li class="nav-item">
                            <form asp-area="Identity"
                                  asp-page="/Account/Logout"
                                  method="post"
                                  class="d-inline">
                                <button type="submit" class="btn btn-danger btn-sm ms-2">
                                    Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white"
                                   asp-area="Identity"
                                   asp-page="/Account/Login">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white"
                                   asp-area="Identity"
                                   asp-page="/Account/Register">
                                Register
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- SCRIPTS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>