@model VgcCollege.Web.Models.Assignment

@{
    ViewData["Title"] = "Edit Assignment";
}

<h2 class="mb-4">Edit Assignment</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control shadow-sm" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="CourseId" class="form-label">Course</label>
        <select asp-for="CourseId"
                asp-items="ViewBag.CourseId"
                class="form-control shadow-sm">
        </select>
        <span asp-validation-for="CourseId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="MaxScore" class="form-label"></label>
        <input asp-for="MaxScore" class="form-control shadow-sm" />
        <span asp-validation-for="MaxScore" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}