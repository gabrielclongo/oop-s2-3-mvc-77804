@model VgcCollege.Web.Models.AssignmentResult

@{
    ViewData["Title"] = "Edit Assignment Result";
}

<h2 class="mb-4">Edit Assignment Result</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="StudentProfileId" class="form-label">Student</label>
        <select asp-for="StudentProfileId"
                asp-items="ViewBag.StudentProfileId"
                class="form-control shadow-sm">
        </select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="AssignmentId" class="form-label">Assignment</label>
        <select asp-for="AssignmentId"
                asp-items="ViewBag.AssignmentId"
                class="form-control shadow-sm">
        </select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Score" class="form-label"></label>
        <input asp-for="Score" class="form-control shadow-sm" />
        <span asp-validation-for="Score" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Feedback" class="form-label"></label>
        <input asp-for="Feedback" class="form-control shadow-sm" />
        <span asp-validation-for="Feedback" class="text-danger"></span>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}